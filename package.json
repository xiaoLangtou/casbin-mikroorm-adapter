{
  "name": "@xltorg/casbin-mikroorm-adapter",
  "version": "2.0.0",
  "description": "MikroORM v6 adapter for Casbin",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "scripts": {
    "precommit": "lint-staged",
    "prepublish": "pnpm run lint && pnpm build",
    "build": "rimraf lib && tsc",
    "coverage": "jest --coverage",
    "lint": "tslint \"src/**/*.ts\"",
    "fix": "tslint \"src/**/*.ts\" --fix",
    "test": "jest --runInBand",
    "release": "npx -p semantic-release -p @semantic-release/git -p @semantic-release/changelog semantic-release",
    "prepare": "npm run build"
  },
  "homepage": "https://casbin.org",
  "keywords": [
    "casbin",
    "node-casbin",
    "adapter",
    "typeorm",
    "access-control",
    "authorization",
    "auth",
    "authz",
    "acl",
    "rbac",
    "abac",
    "orm"
  ],
  "author": "Node-Casbin",
  "devDependencies": {
    "@ava/typescript": "^3.0.1",
    "@types/jest": "^29.5.0",
    "@types/mongodb-memory-server": "^2.3.0",
    "@types/node": "^20.10.0",
    "ava": "^4.2.0",
    "coveralls": "^3.1.1",
    "husky": "^7.0.4",
    "jest": "^29.7.0",
    "lint-staged": "^12.4.1",
    "mongodb-memory-server": "^9.1.0",
    "rimraf": "^3.0.2",
    "ts-jest": "^29.1.0",
    "tslint": "^6.1.3",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@mikro-orm/core": "^6.6.3",
    "@mikro-orm/mongodb": "^6.6.3",
    "casbin": "^5.15.1"
  },
  "peerDependencies": {
    "@mikro-orm/core": "^6.0.0"
  },
  "files": [
    "lib",
    "examples"
  ],
  "lint-staged": {
    "*.{ts,js}": [
      "tslint --fix",
      "git add"
    ]
  },
  "jest": {
    "testURL": "http://localhost",
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest"
    },
    "testTimeout": 30000,
    "testMatch": [
      "**/test/*.+(ts|tsx)"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ]
  }
}
